<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Budget Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0e0e12;
    --surface: #16161e;
    --surface2: #1e1e28;
    --border: #28283a;
    --text: #ededf5;
    --text-muted: #7878a0;
    --text-dim: #404058;
    --green: #4ade80;
    --red: #f87171;
    --blue: #60a5fa;
    --purple: #a78bfa;
    --yellow: #fbbf24;
    --radius: 12px;
    --font: 'Sora', sans-serif;
    --mono: 'IBM Plex Mono', monospace;
  }

  body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; display: grid; grid-template-columns: 260px 1fr; }

  aside {
    border-right: 1px solid var(--border);
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .logo { font-family: var(--mono); font-size: 1rem; font-weight: 500; color: var(--green); padding: 0.5rem 0.75rem; margin-bottom: 0.5rem; }
  .logo span { color: var(--text-muted); }

  .nav-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); padding: 0.5rem 0.75rem; margin-top: 0.75rem; }

  .nav-item { display: flex; align-items: center; gap: 10px; padding: 0.5rem 0.75rem; border-radius: 8px; cursor: pointer; font-size: 0.875rem; color: var(--text-muted); border: none; background: none; width: 100%; text-align: left; transition: all 0.15s; }
  .nav-item:hover { background: var(--surface); color: var(--text); }
  .nav-item.active { background: #4ade8015; color: var(--green); }
  .nav-item .icon { font-size: 1rem; }

  .budget-summary { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; margin: 1rem 0; }
  .budget-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px; }
  .budget-amount { font-family: var(--mono); font-size: 1.25rem; font-weight: 500; color: var(--green); }
  .budget-bar { height: 4px; background: var(--surface2); border-radius: 99px; margin-top: 8px; overflow: hidden; }
  .budget-fill { height: 100%; border-radius: 99px; background: var(--green); transition: width 0.5s ease; }

  main { padding: 2rem; overflow-y: auto; }

  .page { display: none; }
  .page.active { display: block; animation: fadeIn 0.25s ease; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
  .page-title { font-size: 1.4rem; font-weight: 600; letter-spacing: -0.02em; }
  .page-title small { display: block; font-size: 0.8rem; color: var(--text-muted); font-weight: 400; margin-top: 2px; }

  .btn { padding: 0.6rem 1.25rem; border-radius: 8px; font-family: var(--font); font-size: 0.875rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; }
  .btn-green { background: var(--green); color: #0e0e12; }
  .btn-green:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .btn-red { background: #f8717120; color: var(--red); border: 1px solid #f8717140; }
  .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--text-muted); color: var(--text); }
  .btn-sm { padding: 0.35rem 0.75rem; font-size: 0.8rem; }

  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem; }

  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
  .stat-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 8px; }
  .stat-value { font-family: var(--mono); font-size: 1.6rem; font-weight: 500; }
  .stat-value.green { color: var(--green); }
  .stat-value.red { color: var(--red); }
  .stat-value.blue { color: var(--blue); }
  .stat-sub { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; }

  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
  .card-title { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 1rem; }

  .add-form { display: grid; grid-template-columns: 1fr 130px 130px auto auto; gap: 0.75rem; align-items: end; }

  input, select { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-family: var(--font); font-size: 0.875rem; padding: 0.6rem 0.875rem; outline: none; transition: border-color 0.15s; width: 100%; }
  input:focus, select:focus { border-color: var(--green); }
  input::placeholder { color: var(--text-dim); }
  select option { background: var(--surface2); }
  .form-label { font-size: 0.7rem; color: var(--text-muted); margin-bottom: 4px; }

  .tx-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .tx-item { display: flex; align-items: center; gap: 1rem; padding: 0.875rem 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; transition: background 0.15s; }
  .tx-item:hover { background: var(--surface2); }

  .tx-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .tx-body { flex: 1; min-width: 0; }
  .tx-title { font-size: 0.9rem; font-weight: 500; }
  .tx-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }
  .tx-amount { font-family: var(--mono); font-size: 0.95rem; font-weight: 500; }
  .tx-amount.income { color: var(--green); }
  .tx-amount.expense { color: var(--red); }

  .tx-del { background: transparent; border: none; cursor: pointer; color: var(--text-dim); padding: 4px; border-radius: 4px; transition: all 0.15s; font-size: 0.8rem; }
  .tx-del:hover { color: var(--red); background: #f8717115; }

  .cat-tag { display: inline-block; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; padding: 2px 7px; border-radius: 4px; }

  .chart-bars { display: flex; align-items: flex-end; gap: 8px; height: 120px; margin-top: 1rem; }
  .chart-col { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; }
  .chart-bar-wrap { width: 100%; display: flex; flex-direction: column; justify-content: flex-end; height: 100px; gap: 2px; }
  .chart-bar { width: 100%; border-radius: 4px 4px 0 0; transition: height 0.5s ease; min-height: 2px; }
  .chart-month { font-size: 0.65rem; color: var(--text-dim); font-family: var(--mono); }

  .goal-item { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); }
  .goal-item:last-child { border-bottom: none; }
  .goal-icon { font-size: 1.5rem; }
  .goal-body { flex: 1; }
  .goal-name { font-size: 0.9rem; font-weight: 500; }
  .goal-progress { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
  .goal-bar { flex: 1; height: 6px; background: var(--surface2); border-radius: 99px; overflow: hidden; }
  .goal-fill { height: 100%; border-radius: 99px; background: var(--purple); transition: width 0.6s ease; }
  .goal-pct { font-family: var(--mono); font-size: 0.75rem; color: var(--text-muted); }
  .goal-amounts { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }

  .empty { text-align: center; padding: 3rem; color: var(--text-dim); font-size: 0.875rem; }
  .filter-row { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .filter-btn { padding: 0.3rem 0.75rem; border-radius: 99px; font-size: 0.78rem; font-weight: 500; cursor: pointer; border: 1px solid var(--border); background: transparent; color: var(--text-muted); transition: all 0.15s; font-family: var(--font); }
  .filter-btn:hover { border-color: var(--text-muted); color: var(--text); }
  .filter-btn.active { background: #4ade8015; border-color: var(--green); color: var(--green); }
</style>
</head>
<body>

<aside>
  <div class="logo">budget<span>/</span>track</div>

  <div class="budget-summary">
    <div class="budget-label">Monthly Budget</div>
    <div class="budget-amount" id="sb-remaining">$0 left</div>
    <div class="budget-bar"><div class="budget-fill" id="sb-bar" style="width:0%"></div></div>
    <div style="font-size:0.7rem;color:var(--text-dim);margin-top:6px" id="sb-meta">of $0 budget</div>
  </div>

  <div class="nav-label">Navigation</div>
  <button class="nav-item active" onclick="showPage('dashboard', this)"><span class="icon">📊</span> Dashboard</button>
  <button class="nav-item" onclick="showPage('transactions', this)"><span class="icon">💳</span> Transactions</button>
  <button class="nav-item" onclick="showPage('goals', this)"><span class="icon">🎯</span> Goals</button>

  <div class="nav-label">This Month</div>
  <div style="padding:0.5rem 0.75rem;font-size:0.8rem;color:var(--text-muted)" id="sb-income-label">Income: $0</div>
  <div style="padding:0.5rem 0.75rem;font-size:0.8rem;color:var(--text-muted)" id="sb-expense-label">Expenses: $0</div>
</aside>

<main>
  <!-- DASHBOARD -->
  <div class="page active" id="page-dashboard">
    <div class="page-header">
      <div class="page-title">Dashboard <small id="dash-month">May 2026</small></div>
      <button class="btn btn-green" onclick="showPage('transactions', document.querySelectorAll('.nav-item')[1])">+ Add Transaction</button>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Income</div>
        <div class="stat-value green" id="stat-income">$0</div>
        <div class="stat-sub" id="stat-income-count">0 transactions</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Expenses</div>
        <div class="stat-value red" id="stat-expenses">$0</div>
        <div class="stat-sub" id="stat-expense-count">0 transactions</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Net Balance</div>
        <div class="stat-value blue" id="stat-balance">$0</div>
        <div class="stat-sub">This month</div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Spending by Category</div>
      <div id="cat-breakdown"></div>
    </div>

    <div class="card">
      <div class="card-title">Recent Transactions</div>
      <div id="recent-list"></div>
    </div>
  </div>

  <!-- TRANSACTIONS -->
  <div class="page" id="page-transactions">
    <div class="page-header">
      <div class="page-title">Transactions <small>All income & expenses</small></div>
    </div>

    <div class="card">
      <div class="card-title">Add Transaction</div>
      <div class="add-form">
        <div>
          <div class="form-label">Description</div>
          <input type="text" id="tx-desc" placeholder="e.g. Grocery run"/>
        </div>
        <div>
          <div class="form-label">Amount ($)</div>
          <input type="text" id="tx-amount" placeholder="0.00"/>
        </div>
        <div>
          <div class="form-label">Category</div>
          <select id="tx-cat">
            <option value="Food">🍔 Food</option>
            <option value="Transport">🚗 Transport</option>
            <option value="Housing">🏠 Housing</option>
            <option value="Entertainment">🎮 Entertainment</option>
            <option value="Health">💊 Health</option>
            <option value="Education">📚 Education</option>
            <option value="Shopping">🛍️ Shopping</option>
            <option value="Income">💵 Income</option>
            <option value="Other">📦 Other</option>
          </select>
        </div>
        <div>
          <div class="form-label">Type</div>
          <select id="tx-type">
            <option value="expense">Expense</option>
            <option value="income">Income</option>
          </select>
        </div>
        <div style="padding-top:18px">
          <button class="btn btn-green" onclick="addTransaction()">Add</button>
        </div>
      </div>
    </div>

    <div class="filter-row" id="filter-row">
      <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
      <button class="filter-btn" onclick="setFilter('income', this)">Income</button>
      <button class="filter-btn" onclick="setFilter('expense', this)">Expenses</button>
      <button class="filter-btn" onclick="setFilter('Food', this)">Food</button>
      <button class="filter-btn" onclick="setFilter('Transport', this)">Transport</button>
      <button class="filter-btn" onclick="setFilter('Entertainment', this)">Entertainment</button>
    </div>

    <div class="tx-list" id="tx-list"></div>
  </div>

  <!-- GOALS -->
  <div class="page" id="page-goals">
    <div class="page-header">
      <div class="page-title">Savings Goals <small>Track your targets</small></div>
    </div>

    <div class="card">
      <div class="card-title">Your Goals</div>
      <div id="goals-list"></div>
    </div>

    <div class="card">
      <div class="card-title">Monthly Spending Chart</div>
      <div class="chart-bars" id="chart-bars"></div>
    </div>
  </div>
</main>

<script>
const CAT_COLORS = {
  Food: '#f0883e', Transport: '#58a6ff', Housing: '#a78bfa',
  Entertainment: '#f472b6', Health: '#4ade80', Education: '#34d399',
  Shopping: '#fbbf24', Income: '#4ade80', Other: '#7878a0'
};

let transactions = [
  { id: 1, desc: "Part-time job paycheck", amount: 800, cat: "Income", type: "income", date: "2026-05-01" },
  { id: 2, desc: "Apartment rent", amount: 650, cat: "Housing", type: "expense", date: "2026-05-01" },
  { id: 3, desc: "Grocery run", amount: 85, cat: "Food", type: "expense", date: "2026-05-03" },
  { id: 4, desc: "Uber to campus", amount: 12, cat: "Transport", type: "expense", date: "2026-05-04" },
  { id: 5, desc: "Netflix subscription", amount: 16, cat: "Entertainment", type: "expense", date: "2026-05-05" },
  { id: 6, desc: "Freelance project", amount: 350, cat: "Income", type: "income", date: "2026-05-08" },
  { id: 7, desc: "Textbooks", amount: 120, cat: "Education", type: "expense", date: "2026-05-09" },
  { id: 8, desc: "Pizza with friends", amount: 28, cat: "Food", type: "expense", date: "2026-05-10" },
];

const goals = [
  { icon: "💻", name: "New Laptop", target: 1200, saved: 480 },
  { icon: "✈️", name: "Summer Trip", target: 2000, saved: 750 },
  { icon: "🏦", name: "Emergency Fund", target: 3000, saved: 1200 },
];

const BUDGET = 1500;
let nextId = 9;
let txFilter = 'all';

function showPage(name, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  el.classList.add('active');
  renderAll();
}

function addTransaction() {
  const desc = document.getElementById('tx-desc').value.trim();
  const amount = parseFloat(document.getElementById('tx-amount').value);
  const cat = document.getElementById('tx-cat').value;
  const type = document.getElementById('tx-type').value;
  if (!desc || isNaN(amount) || amount <= 0) return;
  transactions.unshift({ id: nextId++, desc, amount, cat, type, date: new Date().toISOString().split('T')[0] });
  document.getElementById('tx-desc').value = '';
  document.getElementById('tx-amount').value = '';
  renderAll();
}

function deleteTransaction(id) {
  transactions = transactions.filter(t => t.id !== id);
  renderAll();
}

function setFilter(f, el) {
  txFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  renderTxList();
}

function fmt(n) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

function renderAll() {
  renderStats();
  renderSidebar();
  renderTxList();
  renderRecent();
  renderCatBreakdown();
  renderGoals();
  renderChart();
}

function getStats() {
  const income = transactions.filter(t => t.type === 'income').reduce((s, t) => s + t.amount, 0);
  const expenses = transactions.filter(t => t.type === 'expense').reduce((s, t) => s + t.amount, 0);
  return { income, expenses, balance: income - expenses };
}

function renderStats() {
  const { income, expenses, balance } = getStats();
  document.getElementById('stat-income').textContent = fmt(income);
  document.getElementById('stat-expenses').textContent = fmt(expenses);
  document.getElementById('stat-balance').textContent = fmt(balance);
  document.getElementById('stat-income-count').textContent = transactions.filter(t => t.type === 'income').length + ' transactions';
  document.getElementById('stat-expense-count').textContent = transactions.filter(t => t.type === 'expense').length + ' transactions';
  document.getElementById('dash-month').textContent = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

function renderSidebar() {
  const { income, expenses } = getStats();
  const remaining = BUDGET - expenses;
  const pct = Math.min(100, (expenses / BUDGET) * 100);
  document.getElementById('sb-remaining').textContent = fmt(Math.max(0, remaining)) + ' left';
  document.getElementById('sb-bar').style.width = pct + '%';
  document.getElementById('sb-bar').style.background = pct > 80 ? '#f87171' : '#4ade80';
  document.getElementById('sb-meta').textContent = 'of ' + fmt(BUDGET) + ' budget';
  document.getElementById('sb-income-label').textContent = 'Income: ' + fmt(income);
  document.getElementById('sb-expense-label').textContent = 'Expenses: ' + fmt(expenses);
}

function renderTxList() {
  const filtered = transactions.filter(t => {
    if (txFilter === 'all') return true;
    if (txFilter === 'income' || txFilter === 'expense') return t.type === txFilter;
    return t.cat === txFilter;
  });
  const el = document.getElementById('tx-list');
  if (filtered.length === 0) { el.innerHTML = '<div class="empty">No transactions found</div>'; return; }
  el.innerHTML = filtered.map(t => `
    <div class="tx-item">
      <div class="tx-dot" style="background:${CAT_COLORS[t.cat] || '#7878a0'}"></div>
      <div class="tx-body">
        <div class="tx-title">${t.desc}</div>
        <div class="tx-meta">${t.date} · <span class="cat-tag" style="background:${CAT_COLORS[t.cat]}20;color:${CAT_COLORS[t.cat]}">${t.cat}</span></div>
      </div>
      <div class="tx-amount ${t.type}">${t.type === 'income' ? '+' : '-'}${fmt(t.amount)}</div>
      <button class="tx-del" onclick="deleteTransaction(${t.id})">✕</button>
    </div>`).join('');
}

function renderRecent() {
  const recent = transactions.slice(0, 5);
  const el = document.getElementById('recent-list');
  if (recent.length === 0) { el.innerHTML = '<div class="empty">No transactions yet</div>'; return; }
  el.innerHTML = recent.map(t => `
    <div class="tx-item">
      <div class="tx-dot" style="background:${CAT_COLORS[t.cat] || '#7878a0'}"></div>
      <div class="tx-body">
        <div class="tx-title">${t.desc}</div>
        <div class="tx-meta">${t.date} · ${t.cat}</div>
      </div>
      <div class="tx-amount ${t.type}">${t.type === 'income' ? '+' : '-'}${fmt(t.amount)}</div>
    </div>`).join('');
}

function renderCatBreakdown() {
  const expenses = transactions.filter(t => t.type === 'expense');
  const total = expenses.reduce((s, t) => s + t.amount, 0);
  const cats = {};
  expenses.forEach(t => { cats[t.cat] = (cats[t.cat] || 0) + t.amount; });
  const sorted = Object.entries(cats).sort((a, b) => b[1] - a[1]);
  const el = document.getElementById('cat-breakdown');
  if (sorted.length === 0) { el.innerHTML = '<div class="empty">No expenses yet</div>'; return; }
  el.innerHTML = sorted.map(([cat, amt]) => {
    const pct = total > 0 ? Math.round((amt / total) * 100) : 0;
    return `
      <div style="margin-bottom:0.75rem">
        <div style="display:flex;justify-content:space-between;font-size:0.85rem;margin-bottom:4px">
          <span>${cat}</span>
          <span style="font-family:var(--mono);color:var(--text-muted)">${fmt(amt)} <span style="color:var(--text-dim)">(${pct}%)</span></span>
        </div>
        <div style="height:6px;background:var(--surface2);border-radius:99px;overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${CAT_COLORS[cat]};border-radius:99px;transition:width 0.5s ease"></div>
        </div>
      </div>`;
  }).join('');
}

function renderGoals() {
  document.getElementById('goals-list').innerHTML = goals.map(g => {
    const pct = Math.round((g.saved / g.target) * 100);
    return `
      <div class="goal-item">
        <div class="goal-icon">${g.icon}</div>
        <div class="goal-body">
          <div class="goal-name">${g.name}</div>
          <div class="goal-amounts">${fmt(g.saved)} saved of ${fmt(g.target)}</div>
          <div class="goal-progress">
            <div class="goal-bar"><div class="goal-fill" style="width:${pct}%"></div></div>
            <div class="goal-pct">${pct}%</div>
          </div>
        </div>
      </div>`;
  }).join('');
}

function renderChart() {
  const months = ['Jan','Feb','Mar','Apr','May','Jun'];
  const data = [820, 1050, 760, 940, 1130, getStats().expenses];
  const max = Math.max(...data);
  document.getElementById('chart-bars').innerHTML = months.map((m, i) => {
    const h = max > 0 ? Math.round((data[i] / max) * 90) : 0;
    const isThis = i === months.length - 1;
    return `
      <div class="chart-col">
        <div class="chart-bar-wrap">
          <div class="chart-bar" style="height:${h}px;background:${isThis ? 'var(--green)' : 'var(--surface2)'}"></div>
        </div>
        <div class="chart-month" style="color:${isThis ? 'var(--green)' : 'var(--text-dim)'}">${m}</div>
      </div>`;
  }).join('');
}

renderAll();
</script>
</body>
</html>
